<Window x:Class="Morse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Morse"
        mc:Ignorable="d"
        Title="Trainer" Height="380" Width="340"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp" Background="#F0F0F0" ResizeMode="CanResize" MinHeight="320" MinWidth="280">
    <Grid>
        <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="10">
            
            <!-- Mode Toggle -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                <Button x:Name="MorseModeButton" Content="Morse" Click="MorseModeButton_Click"
                        Padding="10,5" FontSize="12" FontWeight="Bold" Cursor="Hand" MinWidth="60" Margin="0,0,3,0"/>
                <Button x:Name="ChordModeButton" Content="Chord" Click="ChordModeButton_Click"
                        Padding="10,5" FontSize="12" FontWeight="Bold" Cursor="Hand" MinWidth="60" Margin="3,0,3,0"/>
                <Button x:Name="LearnModeButton" Content="Learn" Click="LearnModeButton_Click"
                        Padding="10,5" FontSize="12" FontWeight="Bold" Cursor="Hand" MinWidth="60" Margin="3,0,0,0"/>
            </StackPanel>

            <!-- Learn Info Panel -->
            <Border x:Name="LearnPanel" Visibility="Collapsed" Margin="0,0,0,5" Background="#FFEEDD" Padding="6" CornerRadius="3">
                <StackPanel>
                    <TextBlock x:Name="LearnLevelText" FontSize="10" FontWeight="Bold" Foreground="#CC6600" Margin="0,0,0,2"/>
                    <TextBlock x:Name="LearnTargetText" FontSize="28" FontWeight="Bold" Foreground="#E65100" 
                               HorizontalAlignment="Center" FontFamily="Courier New"/>
                    <TextBlock x:Name="LearnHintText" FontSize="11" Foreground="#666666" TextAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock x:Name="LearnStreakText" FontSize="9" Foreground="#888888" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Current Input -->
            <StackPanel Margin="0,0,0,5">
                <TextBlock x:Name="InputLabel" Text="Input:" FontSize="11" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,3"/>
                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Padding="8">
                    <TextBlock x:Name="CurrentMorseDisplay" FontSize="18" Foreground="#0066CC" 
                               FontFamily="Courier New" MinHeight="28" TextAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Instruction -->
            <TextBlock x:Name="InstructionText" FontSize="9" Foreground="#666666" TextAlignment="Center" 
                       Margin="0,0,0,5" Text=". = dot  |  - = dash  |  , = space  |  Backspace = delete  |  Space = copy"/>

            <!-- Text Output -->
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Text:" FontSize="11" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,3"/>
                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Padding="8">
                    <TextBlock x:Name="TextDisplay" FontSize="16" Foreground="#00AA00" 
                               FontFamily="Courier New" MinHeight="50" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <Button x:Name="CopyButton" Content="Copy" Click="CopyButton_Click" 
                        Padding="12,6" FontSize="11" Background="#4CAF50" Foreground="White"
                        Cursor="Hand" MinWidth="60" Margin="0,0,5,0"/>
                <Button x:Name="UndoButton" Content="Undo" Click="UndoButton_Click" 
                        Padding="12,6" FontSize="11" Background="#FFC107" Foreground="White"
                        Cursor="Hand" MinWidth="60" Margin="0,0,5,0"/>
                <Button x:Name="ClearButton" Content="Clear" Click="ClearButton_Click" 
                        Padding="12,6" FontSize="11" Background="#FF6B6B" Foreground="White"
                        Cursor="Hand" MinWidth="60" Margin="0,0,5,0"/>
                <Button x:Name="CheatSheetButton" Content="?" Click="CheatSheetButton_Click" 
                        Padding="10,6" FontSize="11" Background="#9C27B0" Foreground="White"
                        Cursor="Hand" MinWidth="40" Margin="0,0,5,0"/>
                <Button x:Name="SettingsButton" Content="⚙" Click="SettingsButton_Click" 
                        Padding="10,6" FontSize="11" Background="#2196F3" Foreground="White"
                        Cursor="Hand" MinWidth="40"/>
            </StackPanel>
            
            <!-- Settings Section -->
            <Border x:Name="SettingsPanel" Visibility="Collapsed" Margin="0,5,0,0" Background="#EFEFEF" Padding="8" CornerRadius="3">
                <StackPanel>
                    <TextBlock Text="Auto-decode delay (seconds):" FontSize="10" FontWeight="Bold" Foreground="#333333" Margin="0,0,2,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Slider x:Name="DelaySlider" Minimum="0.1" Maximum="1.0" SmallChange="0.1" LargeChange="0.1"
                                Value="0.8" TickFrequency="0.1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                ValueChanged="DelaySlider_ValueChanged" Width="140" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DelaySliderValue" FontSize="10" Foreground="#333333" VerticalAlignment="Center" Margin="6,0,0,0" Text="0.8s"/>
                    </StackPanel>
                    <TextBlock Text="Streak timeout (seconds):" FontSize="10" FontWeight="Bold" Foreground="#333333" Margin="0,0,2,0"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="StreakSlider" Minimum="1" Maximum="5" SmallChange="1" LargeChange="1"
                                Value="4" TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                ValueChanged="StreakSlider_ValueChanged" Width="140" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StreakSliderValue" FontSize="10" Foreground="#333333" VerticalAlignment="Center" Margin="6,0,0,0" Text="4s"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Cheat Sheet Section -->
            <Border x:Name="CheatSheetPanel" Visibility="Collapsed" Margin="0,5,0,0" Background="#EFEFEF" Padding="8" CornerRadius="3">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <Grid x:Name="CheatSheetGrid">
                        <!-- Will be populated by code-behind -->
                    </Grid>
                </ScrollViewer>
            </Border>
            
            <!-- Status -->
            <TextBlock x:Name="StatusText" FontSize="9" Foreground="#999999" TextAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Window>